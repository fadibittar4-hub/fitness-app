# Copy this file to .env and fill in your values before running docker compose up

# MySQL root password (used internally by the db container)
DB_ROOT_PASSWORD=change_me_root

# Database connection (used by the backend service)
DB_HOST=db
DB_PORT=3306
DB_NAME=strynth
DB_USER=strynth_user
DB_PASSWORD=change_me_db

# JWT signing secret — use a long random string in production
JWT_SECRET=change_me_jwt_secret
