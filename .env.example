# Copy this file to .env — no changes needed to run locally
# cp .env.example .env

# MySQL root password (used internally by the db container)
DB_ROOT_PASSWORD=strynth_root

# Database connection (used by the backend service)
DB_HOST=db
DB_PORT=3306
DB_NAME=strynth
DB_USER=strynth_user
DB_PASSWORD=strynth_pass

# JWT signing secret — change this in production
JWT_SECRET=strynth_dev_secret_change_in_production
